# ── Postgres (source / app) ───────────────────────────────────────────────────
POSTGRES_APP_USER=
POSTGRES_APP_PASSWORD=
POSTGRES_APP_DB=

# ── Postgres (analytics / destination) ───────────────────────────────────────
POSTGRES_ANALYTICS_USER=
POSTGRES_ANALYTICS_PASSWORD=
POSTGRES_ANALYTICS_DB=

# ── Bruin: raw ingest (source PG → analytics PG) ────────────────────────────
RAW_SOURCE_PG_DSN=postgresql://<user>:<password>@<host>:<port>/<db>
RAW_SOURCE_PG_TABLE=ingest.game_events_raw
RAW_DEST_PG_DSN=postgresql://<user>:<password>@<host>:<port>/<db>
RAW_LOOKBACK_MS=300000
RAW_ASSET_KEY=raw.game_events

# ── Bruin: staging ───────────────────────────────────────────────────────────
STAGING_DEST_PG_DSN=postgresql://<user>:<password>@<host>:<port>/<db>
STAGING_SOURCE_TABLE=raw.game_events
STAGING_ASSET_KEY=staging.game_events
STAGING_LOOKBACK_MS=300000
STATE_TABLE=meta.load_state

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_TOPIC=game_events
KAFKA_GROUP_ID=
GENERATOR_RATE_PER_SEC=100

# ── Streamlit ────────────────────────────────────────────────────────────────
ANALYTICS_PG_DSN=postgresql://<user>:<password>@<host>:<port>/<db>

# ── Airflow ──────────────────────────────────────────────────────────────────
AIRFLOW_FERNET_KEY=
AIRFLOW_PG_DSN=postgresql://<user>:<password>@<host>:<port>/<db>

# ── Misc ─────────────────────────────────────────────────────────────────────
AWS_EC2_METADATA_DISABLED=true
UV_HTTP_TIMEOUT=1000
